LISTEN_HOST=127.0.0.1
LISTEN_PORT=4000

# LM Studio local server
LOCAL_BASE_URL=http://127.0.0.1:1234
LOCAL_API_KEY=
# Leave LOCAL_MODEL empty to enable auto-selection.
LOCAL_MODEL=
LOCAL_CONTEXT_LENGTH=16384
MIN_SAFE_CONTEXT_LENGTH=8192
LOCAL_STRIP_FIELDS=thinking,service_tier,metadata
LOCAL_MAX_TOKENS_CAP=0
STABLE_MODEL_KEY=google/gemma-4-e4b
STABLE_MODEL_IDENTIFIER=gemma-4-e4b-it
FAST_MODEL_KEY=google/gemma-3n-e4b
BALANCED_MODEL_KEY=google/gemma-4-e4b
QUALITY_MODEL_KEY=google/gemma-4-31b
AUTO_SELECT_MODEL=true
RELAY_MODEL_PROFILE=balanced
AUTO_DOWNLOAD_RECOMMENDED_MODEL=false

# Relay local-mode behavior flags
RELAY_FAST_BARE_MODE=true
RELAY_EXCLUDE_DYNAMIC_PROMPT=true
RELAY_LOCAL_EFFORT=medium
RELAY_COMPAT_SYSTEM_PROMPT=
RELAY_MODEL_ALIASES=claude-sonnet-4-6,claude-opus-4-7,claude-opus-4-1,sonnet,opus

# Smart context behavior (session memory + prompt compaction)
SMART_CONTEXT_ENABLED=true
SMART_CONTEXT_STORE_PATH=/tmp/claude-local-relay-context.json
SMART_CONTEXT_KEEP_RECENT_MESSAGES=10
SMART_CONTEXT_MAX_SUMMARY_CHARS=4000
SMART_CONTEXT_MAX_TURN_CHARS=900
SMART_CONTEXT_INJECT_SUMMARY=true

# Fallback policy
FALLBACK_ON_STATUS=402,403,408,409,429,500,502,503,504
FALLBACK_ERROR_KEYWORDS=quota,insufficient,rate-limit,overloaded,credit,billing,retry

# Cloud primary backend: Anthropic-compatible
ENABLE_CLOUD_ANTHROPIC=false
CLOUD_ANTHROPIC_BASE_URL=https://api.anthropic.com
CLOUD_ANTHROPIC_API_KEY=
CLOUD_ANTHROPIC_VERSION=2023-06-01

# Optional cloud backend: OpenAI-compatible
ENABLE_CLOUD_OPENAI=false
CLOUD_OPENAI_BASE_URL=https://api.openai.com
CLOUD_OPENAI_API_KEY=

# API key used by Claude client when pointing to the relay gateway
PROXY_CLIENT_TOKEN=claude-local-relay
